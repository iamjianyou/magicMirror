{
  "name": "smart-mirror-react",
  "private": true,
  "version": "1.0.0",
  "description": "A TypeScript + React rebuild of the MagicMirror² smart mirror (Clock, Compliments, Weather modules)",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "concurrently -k -s first \"vite\" \"wait-on tcp:127.0.0.1:3000 && electron electron/main.cjs\"",
    "dev": "vite",
    "electron": "electron electron/main.cjs",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "electron": "^42.3.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^9.0.10"
  }
}
